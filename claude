<!DOCTYPE html>
<html lang="en" id="html-root">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dr. Abdourahamane Diallo — A Life in Service of Independence</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,600;9..144,700&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --indigo-900:#161f36;
    --indigo-800:#1d2c4d;
    --indigo-700:#2c4070;
    --parchment:#f4ecdc;
    --parchment-dim:#e9ddc6;
    --ink:#211c16;
    --ink-soft:#52483b;
    --guinea-red:#ce1126;
    --guinea-yellow:#fcd116;
    --guinea-green:#0a7a3e;
    --gold:#c8a13b;
    --thread:rgba(200,161,59,0.55);
    --maxw:1120px;
  }

  *{margin:0;padding:0;box-sizing:border-box;}

  html{scroll-behavior:smooth;}

  body{
    background:var(--parchment);
    color:var(--ink);
    font-family:'Source Serif 4', Georgia, serif;
    line-height:1.7;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }

  h1,h2,h3,.display{
    font-family:'Fraunces', serif;
    font-weight:600;
    letter-spacing:-0.01em;
  }

  .eyebrow{
    font-family:'Space Mono', monospace;
    text-transform:uppercase;
    letter-spacing:0.18em;
    font-size:0.72rem;
    font-weight:700;
  }

  .flag-stripe{
    height:6px;
    width:100%;
    display:flex;
  }
  .flag-stripe span{flex:1;}
  .flag-stripe .r{background:var(--guinea-red);}
  .flag-stripe .y{background:var(--guinea-yellow);}
  .flag-stripe .g{background:var(--guinea-green);}

  /* ===== LANGUAGE TOGGLE ===== */
  .lang-fr{display:none;}
  body.fr .lang-en{display:none;}
  body.fr .lang-fr{display:revert;}

  .lang-switch{
    display:flex;
    align-items:center;
    gap:0.4rem;
    font-family:'Space Mono', monospace;
    font-size:0.72rem;
    letter-spacing:0.1em;
    flex-shrink:0;
  }
  .lang-switch button{
    background:transparent;
    border:1px solid rgba(244,236,220,0.35);
    color:var(--parchment-dim);
    border-radius:3px;
    padding:0.35rem 0.6rem;
    cursor:pointer;
    font-family:inherit;
    font-size:inherit;
    letter-spacing:inherit;
    transition:background .2s, color .2s, border-color .2s;
  }
  .lang-switch button.active{
    background:var(--guinea-yellow);
    color:var(--indigo-900);
    border-color:var(--guinea-yellow);
    font-weight:700;
  }
  .lang-switch button:hover:not(.active){
    border-color:var(--guinea-yellow);
    color:var(--guinea-yellow);
  }

  /* ===== NAV ===== */
  header.site-nav{
    position:sticky;
    top:0;
    z-index:50;
    background:var(--indigo-900);
    color:var(--parchment);
  }
  .nav-inner{
    max-width:var(--maxw);
    margin:0 auto;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:0.85rem 1.5rem;
    gap:1rem;
  }
  .nav-name{
    font-family:'Fraunces', serif;
    font-size:1.05rem;
    font-weight:600;
    letter-spacing:0.02em;
    white-space:nowrap;
  }
  .nav-name span{color:var(--guinea-yellow);}
  .nav-right{
    display:flex;
    align-items:center;
    gap:1.6rem;
  }
  .nav-links{
    display:flex;
    gap:1.6rem;
    font-family:'Space Mono', monospace;
    font-size:0.72rem;
    text-transform:uppercase;
    letter-spacing:0.12em;
  }
  .nav-links a{
    color:var(--parchment-dim);
    text-decoration:none;
    border-bottom:1px solid transparent;
    padding-bottom:4px;
    transition:color .2s, border-color .2s;
  }
  .nav-links a:hover, .nav-links a:focus-visible{
    color:var(--guinea-yellow);
    border-color:var(--guinea-yellow);
  }
  @media (max-width:680px){
    .nav-links{display:none;}
  }

  /* ===== HERO ===== */
  .hero{
    background:
      radial-gradient(ellipse at 50% -10%, rgba(200,161,59,0.18), transparent 55%),
      repeating-linear-gradient(135deg, rgba(255,255,255,0.025) 0 2px, transparent 2px 26px),
      repeating-linear-gradient(45deg, rgba(255,255,255,0.025) 0 2px, transparent 2px 26px),
      var(--indigo-900);
    color:var(--parchment);
    padding:6rem 1.5rem 5rem;
    text-align:center;
    border-bottom:1px solid rgba(200,161,59,0.35);
  }
  .hero-inner{max-width:780px;margin:0 auto;}
  .hero .eyebrow{color:var(--guinea-yellow); display:block; margin-bottom:1.4rem;}
  .hero h1{
    font-size:clamp(2.4rem, 8vw, 4.6rem);
    line-height:1.05;
    margin-bottom:0.6rem;
    word-break:break-word;
  }
  .hero .subtitle{
    font-family:'Fraunces', serif;
    font-style:italic;
    font-weight:300;
    font-size:clamp(1.05rem, 3vw, 1.5rem);
    color:var(--parchment-dim);
    margin-bottom:2rem;
  }
  .hero-flag{
    display:inline-flex;
    gap:6px;
    margin-top:0.5rem;
  }
  .hero-flag span{
    width:42px;
    height:6px;
    border-radius:2px;
  }

  /* ===== SECTION SHELL ===== */
  section{
    padding:5rem 1.5rem;
  }
  @media (max-width:600px){
    section{padding:3.5rem 1.25rem;}
  }
  .section-inner{
    max-width:var(--maxw);
    margin:0 auto;
  }
  .section-head{
    max-width:680px;
    margin-bottom:3rem;
  }
  .section-head .eyebrow{color:var(--guinea-green); margin-bottom:0.8rem; display:block;}
  .section-head h2{
    font-size:clamp(1.7rem, 5.5vw, 2.6rem);
    margin-bottom:0.9rem;
  }
  .section-head p{color:var(--ink-soft); font-size:1.05rem;}

  .lede{
    font-size:1.18rem;
    color:var(--ink-soft);
  }
  .lede strong{color:var(--ink); font-weight:600;}

  /* thread divider, evoking Fouta-Djallon indigo-cloth stitching */
  .thread{
    height:1px;
    background-image: repeating-linear-gradient(to right, var(--thread) 0 10px, transparent 10px 18px);
    margin:3.5rem 0;
  }

  /* ===== BIOGRAPHY ===== */
  .bio{
    background:var(--parchment);
  }
  .bio-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:2.4rem;
  }
  .bio-grid p{margin-bottom:1.2rem; max-width:760px;}

  /* ===== PILLARS ===== */
  .pillars{
    background:var(--indigo-900);
    color:var(--parchment);
  }
  .pillars .section-head .eyebrow{color:var(--guinea-yellow);}
  .pillars .section-head h2{color:var(--parchment);}
  .pillars .section-head p{color:var(--parchment-dim);}

  .pillar-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:1.5rem;
  }
  @media (max-width:880px){
    .pillar-grid{grid-template-columns:1fr;}
  }
  .pillar-card{
    background:var(--indigo-800);
    border:1px solid rgba(200,161,59,0.25);
    border-radius:4px;
    padding:2rem 1.7rem;
    position:relative;
    overflow:hidden;
  }
  .pillar-card::before{
    content:'';
    position:absolute;
    top:0; left:0;
    width:100%;
    height:4px;
    background:linear-gradient(to right, var(--guinea-red), var(--guinea-yellow), var(--guinea-green));
  }
  .pillar-year{
    font-family:'Space Mono', monospace;
    font-size:2.6rem;
    font-weight:700;
    color:var(--guinea-yellow);
    line-height:1;
    margin-bottom:0.6rem;
  }
  .pillar-card h3{
    font-size:1.2rem;
    margin-bottom:0.9rem;
    color:var(--parchment);
  }
  .pillar-card p{
    color:var(--parchment-dim);
    font-size:0.97rem;
  }

  /* ===== JOURNEY MAP (signature element) ===== */
  .journey{
    background:var(--parchment-dim);
  }
  .journey-map{
    width:100%;
    max-width:var(--maxw);
    margin:0 auto 1rem;
    display:block;
  }
  .journey-map .route{
    stroke:var(--gold);
    stroke-width:2;
    stroke-dasharray:1 9;
    stroke-linecap:round;
    fill:none;
  }
  .journey-map .node circle{
    fill:var(--indigo-900);
    stroke:var(--guinea-yellow);
    stroke-width:2;
  }
  .journey-map .node text{
    font-family:'Space Mono', monospace;
    font-size:11px;
    fill:var(--ink);
  }
  .journey-map .node .place{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:14px;
    fill:var(--ink);
  }

  /* ===== TIMELINE ===== */
  .timeline{
    background:var(--parchment-dim);
  }
  .tl-list{
    position:relative;
    border-left:2px dashed var(--gold);
    margin-left:0.6rem;
    padding-left:2.2rem;
  }
  @media (max-width:500px){
    .tl-list{margin-left:0.2rem; padding-left:1.4rem;}
  }
  .tl-item{
    position:relative;
    margin-bottom:2.6rem;
  }
  .tl-item:last-child{margin-bottom:0;}
  .tl-item::before{
    content:'';
    position:absolute;
    left:-2.55rem;
    top:0.3rem;
    width:14px;
    height:14px;
    border-radius:50%;
    background:var(--guinea-yellow);
    border:2px solid var(--indigo-900);
  }
  @media (max-width:500px){
    .tl-item::before{left:-1.75rem; width:12px; height:12px;}
  }
  .tl-date{
    font-family:'Space Mono', monospace;
    font-size:0.72rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--guinea-green);
    margin-bottom:0.35rem;
    display:block;
  }
  .tl-item h3{
    font-size:1.25rem;
    margin-bottom:0.4rem;
  }
  .tl-item p{
    color:var(--ink-soft);
    max-width:680px;
  }

  /* ===== FAMILY / LEGACY ===== */
  .family{
    background:var(--parchment);
  }
  .family-grid{
    display:grid;
    grid-template-columns:1.1fr 0.9fr;
    gap:3rem;
    align-items:start;
  }
  @media (max-width:780px){
    .family-grid{grid-template-columns:1fr;}
  }
  .family-card{
    background:var(--indigo-900);
    color:var(--parchment);
    border-radius:4px;
    padding:2.4rem;
    position:relative;
  }
  .family-card::before{
    content:'';
    position:absolute;
    top:0; left:0; right:0;
    height:4px;
    background:linear-gradient(to right, var(--guinea-red), var(--guinea-yellow), var(--guinea-green));
  }
  .family-card .eyebrow{color:var(--guinea-yellow); display:block; margin-bottom:0.8rem;}
  .family-card h3{font-size:1.4rem; margin-bottom:0.8rem;}
  .family-card p{color:var(--parchment-dim);}

  /* ===== CLOSING / EPITAPH ===== */
  .epitaph{
    background:var(--indigo-900);
    color:var(--parchment);
    text-align:center;
    padding:6rem 1.5rem;
  }
  @media (max-width:600px){
    .epitaph{padding:4rem 1.25rem;}
  }
  .epitaph blockquote{
    font-family:'Fraunces', serif;
    font-style:italic;
    font-weight:300;
    font-size:clamp(1.3rem, 4.5vw, 2.2rem);
    max-width:760px;
    margin:0 auto 1.5rem;
    line-height:1.5;
  }
  .epitaph cite{
    font-family:'Space Mono', monospace;
    font-size:0.72rem;
    letter-spacing:0.16em;
    text-transform:uppercase;
    color:var(--guinea-yellow);
    font-style:normal;
  }

  /* ===== FOOTER ===== */
  footer{
    background:var(--ink);
    color:var(--parchment-dim);
    text-align:center;
    padding:2.5rem 1.5rem 2rem;
    font-family:'Space Mono', monospace;
    font-size:0.75rem;
    letter-spacing:0.06em;
  }
  footer .hero-flag{margin-bottom:1rem;}

  /* reveal on scroll */
  .reveal{
    opacity:0;
    transform:translateY(18px);
    transition:opacity .7s ease, transform .7s ease;
  }
  .reveal.is-visible{
    opacity:1;
    transform:translateY(0);
  }
  @media (prefers-reduced-motion: reduce){
    .reveal{opacity:1; transform:none; transition:none;}
    html{scroll-behavior:auto;}
  }
</style>
</head>
<body>

<div class="flag-stripe"><span class="r"></span><span class="y"></span><span class="g"></span></div>

